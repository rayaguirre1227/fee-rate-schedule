# GitHub Integration Configuration
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (with repo write permissions)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# GitHub Repository (format: owner/repo)
# Example: myusername/fee-schedule-repo
GITHUB_REPO=owner/repo

# File path in the repository where data will be saved (optional)
# Default: fee-schedule-data.json
GITHUB_FILE_PATH=fee-schedule-data.json
